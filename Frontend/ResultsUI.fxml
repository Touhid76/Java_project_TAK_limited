<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.TenantController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 15 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Button text="← Back" onAction="#back" style="-fx-background-color: #f1f3f5; -fx-text-fill: #333; -fx-background-radius: 20;"/>
            <Label text="Available Properties" textFill="#2c3e50"><font><Font name="System Bold" size="18"/></font></Label>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 20;">
            <content>
                <VBox fx:id="resultsContainer" spacing="20" alignment="TOP_CENTER" style="-fx-background-color: #f4f6f9;"/>
            </content>
        </ScrollPane>
    </center>
</BorderPane>