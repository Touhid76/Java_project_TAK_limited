<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.TenantController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 15 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="TAK TENANT" textFill="#007bff"><font><Font name="System Bold" size="22"/></font></Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#logout" style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-border-color: #e74c3c; -fx-border-radius: 20;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="30">
            <Label text="Find Your Perfect Space" textFill="#2c3e50"><font><Font name="System Bold" size="36"/></font></Label>

            <VBox maxWidth="600" spacing="20" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 20, 0, 0, 0);">
                <Label text="SEARCH FILTERS" textFill="#aaa"><font><Font name="System Bold" size="12"/></font></Label>

                <ComboBox fx:id="searchLocation" promptText="Select Location" prefWidth="550" style="-fx-padding: 8; -fx-font-size: 14px; -fx-background-color: #f8f9fa; -fx-border-color: #eee;"/>

                <HBox spacing="15">
                    <TextField fx:id="maxRent" promptText="Max Rent (BDT)" HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-color: #f8f9fa; -fx-border-color: #eee;"/>
                    <TextField fx:id="minSize" promptText="Min Size (Sq. Ft)" HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-color: #f8f9fa; -fx-border-color: #eee;"/>
                </HBox>

                <Button text="SEARCH NOW 🔍" onAction="#searchFlats" prefWidth="550" style="-fx-background-color: linear-gradient(to right, #007bff, #0056b3); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 5; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>